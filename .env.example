# Environment template — copy to .env locally and fill in.
# NEVER commit the real .env file (already in .gitignore).

# === LLM providers ===
# MiniMax (Token Plan key)
MINIMAX_API_KEY=
# xAI (Grok 4.3)
XAI_API_KEY=
# Anthropic (Opus 4.7 backup, via Perplexity Computer normally — only set if you call directly)
ANTHROPIC_API_KEY=

# === Datastore (example: Supabase) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# === Messaging (gates) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
# or WhatsApp via your preferred provider
WHATSAPP_API_TOKEN=

# === Observability ===
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Costrict ===
COSTRICT_MCP_ENDPOINT=

# === Feature flags ===
FEATURE_FLAGS_PROVIDER=

# Add app-specific vars below
